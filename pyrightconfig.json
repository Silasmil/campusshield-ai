{
  "typeCheckingMode": "basic",
  "pythonVersion": "3.14",
  "pythonPath": "${workspaceFolder}/venv_new/Scripts/python.exe",
  "venvPath": "${workspaceFolder}/venv_new",
  "include": ["campusshield"],
  "exclude": [
    "**/*",
    "!campusshield",
    "node_modules",
    "__pycache__",
    ".venv",
    "venv",
    "venv_new",
    ".git",
    ".pytest_cache",
    "*.egg-info",
    "dist",
    "build"
  ],
  "extraPaths": ["${workspaceFolder}/campusshield"],
  "reportMissingImports": false,
  "reportMissingTypeStubs": false
}
