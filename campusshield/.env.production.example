# CampusShield AI - Production Environment Configuration
# Copy this to .env and fill in your values

# ========================================
# REQUIRED: Environment Type
# ========================================
DJANGO_ENVIRONMENT=production

# ========================================
# REQUIRED: Security Keys
# ========================================
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-long-random-secret-key-here-minimum-50-characters

# ========================================
# REQUIRED: Allowed Hosts
# ========================================
# Comma-separated list of allowed domains
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ========================================
# REQUIRED: Database Configuration
# ========================================
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/campusshield_db
# Or using individual variables:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=campusshield_db
# DB_USER=postgres_user
# DB_PASSWORD=secure_password_here
# DB_HOST=database.example.com
# DB_PORT=5432

# ========================================
# SECURITY Settings
# ========================================
# Debug mode - MUST be False in production
DJANGO_DEBUG=False

# Email configuration for alerts
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# ========================================
# Optional: Logging Configuration
# ========================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/django/campusshield.log

# ========================================
# Optional: SSL/HTTPS
# ========================================
# If using self-signed certificates:
# SSL_CERT_FILE=/path/to/cert.pem
# SSL_KEY_FILE=/path/to/key.pem

# Proxy headers (if behind reverse proxy like Nginx)
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO:https

# ========================================
# Optional: Third-party Services
# ========================================
# Sentry for error tracking (optional)
# SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# ========================================
# Optional: Performance
# ========================================
# Cache configuration
CACHE_URL=redis://localhost:6379/0

# ========================================
# IMPORTANT SECURITY REMINDERS
# ========================================
# 1. NEVER commit this file to version control
# 2. NEVER share SECRET_KEY with anyone
# 3. NEVER use DEBUG=True in production
# 4. ALWAYS use HTTPS in production
# 5. ALWAYS use strong database passwords
# 6. ALWAYS restrict ALLOWED_HOSTS
# 7. REGULARLY update all dependencies
# 8. MONITOR and LOG all access attempts
